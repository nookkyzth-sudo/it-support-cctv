generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model branches {
  branch_id   Int      @id @default(autoincrement())
  branch_name String   @unique @db.VarChar(100)
  zone        String?  @db.VarChar(50)
  users       users[]
  tickets     tickets[]
}

model categories {
  category_id   Int      @id @default(autoincrement())
  category_name String   @unique @db.VarChar(100)
  tickets       tickets[]
}

model users {
  user_id    String   @id @db.Uuid
  name       String   @db.VarChar(100)
  email      String?  @unique @db.VarChar(255)
  role       user_role @default(staff)
  branch_id  Int?
  branch     branches? @relation(fields: [branch_id], references: [branch_id])
  tickets    tickets[] @relation("reporter")
  tech_tickets tickets[] @relation("technician")
  attachments ticket_attachments[]
  logs       ticket_logs[]

  @@map("users")
}

model tickets {
  ticket_id        Int      @id @default(autoincrement())
  branch_id        Int
  branch           branches @relation(fields: [branch_id], references: [branch_id])
  category_id      Int
  category         categories @relation(fields: [category_id], references: [category_id])
  reporter_id      String   @db.Uuid
  reporter         users    @relation("reporter", fields: [reporter_id], references: [user_id])
  report_date      DateTime @default(now()) @db.Timestamptz()
  issue_description String  @db.Text
  status           ticket_status @default(Pending)
  technician_id    String?  @db.Uuid
  technician       users?   @relation("technician", fields: [technician_id], references: [user_id])
  technician_note  String?  @db.Text
  resolved_date    DateTime? @db.Timestamptz()
  attachments      ticket_attachments[]
  logs             ticket_logs[]
}

model ticket_attachments {
  attachment_id Int      @id @default(autoincrement())
  ticket_id     Int
  ticket        tickets  @relation(fields: [ticket_id], references: [ticket_id])
  file_path     String   @db.VarChar(255)
  type          attachment_type
  uploaded_by   String   @db.Uuid
  uploader      users    @relation(fields: [uploaded_by], references: [user_id])
  uploaded_at   DateTime @default(now()) @db.Timestamptz()

  @@map("ticket_attachments")
}

model ticket_logs {
  log_id     Int      @id @default(autoincrement())
  ticket_id  Int
  ticket     tickets  @relation(fields: [ticket_id], references: [ticket_id])
  old_status ticket_status?
  new_status ticket_status
  note       String?  @db.Text
  changed_by String   @db.Uuid
  changer    users    @relation(fields: [changed_by], references: [user_id])
  changed_at DateTime @default(now()) @db.Timestamptz()

  @@map("ticket_logs")
}

enum user_role {
  staff
  technician
  admin

  @@map("user_role")
}

enum ticket_status {
  Pending
  In_Progress
  Claim
  Resolved

  @@map("ticket_status")
}

enum attachment_type {
  before
  after

  @@map("attachment_type")
}
